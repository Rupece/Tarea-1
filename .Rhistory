names(db) = c("MES","AEROCALAFIA","AEROMAR","AEROMEXICO","INTERJET","MAGNICHARTERS","TAR","VIVAAEROBUS","VOLARIS","Q","AEROLINEAS","Pturbo","IG","II","IP","W","IPPa","IPPt","IGAE")
QIPPt <- db$Q*db$IPPt
Ln(Q) <- ln(db$Q)
Ln(Q) <- log(db$Q)
Ln(Q) <- log(db$Q)
lnQ <- log(db$Q)
LnW <- log(db$W)
Demanda <- db$IPPa ~ db$Q + db$IGAE + db$IPPt + QIPPt
CPO <- db$IPPa ~ lnQ + LnW + db$Q + QIPPt
system <- list(eq1 = Demanda, eq2 = CPO)
reg3SLS <- systemfit(system, "3SLS", data = db)
instrumentos <- ~ lag(db$Q,-1) + lag(db$IGAE,-1) + lag(db$IPPt,-1) + lag(QIPPt,-1) + lag(lnQ,-1) + lag(LnW,-1)
reg3SLS <- systemfit(system, "3SLS", inst = instrumentos, data = db)
summary(reg3SLS)
instrumentos <- ~ lag(db$Q,-1) + lag(db$IGAE,-1) + lag(db$IPPt,-1) + lag(QIPPt,-1)
