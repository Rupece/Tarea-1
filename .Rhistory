help("lag")
ts(db)
ts(db$Q, frequency = 12)
tsIPPt <- ts(db$IPPt, frequency = 12)
tsQ <- ts(db$Q, frequency = 12)
tsIPPa <- ts(db$IPPa, frequency = 12)
tsIGAE <- ts(db$IGAE, frequency = 12)
tsQIPPt <- ts(QIPPt, frequency = 12)
tsQ <- ts(db$Q, start = c(2013,1), frequency = 12)
tsIPPa <- ts(db$IPPa,start = c(2013,1), frequency = 12)
tsIPPt <- ts(db$IPPt,start = c(2013,1), frequency = 12)
tsIGAE <- ts(db$IGAE,start = c(2013,1), frequency = 12)
tsQIPPt <- ts(QIPPt,start = c(2013,1) frequency = 12)
db$QIPPt <- db$Q*db$IPPt
db$lnQ <- log(db$Q)
db$LnW <- log(db$W)
tsQIPPt <- ts(db$QIPPt,start = c(2013,1) frequency = 12)
tslnQ <- ts(db$lnQ,start = c(2013,1) frequency = 12)
tslnW <- ts(db$LnW,start = c(2013,1) frequency = 12)
tsQIPPt <- ts(db$QIPPt,start = c(2013,1), frequency = 12)
tslnQ <- ts(db$lnQ,start = c(2013,1), frequency = 12)
tslnW <- ts(db$LnW,start = c(2013,1), frequency = 12)
Demanda <- tsIPPa ~ tsQ + tsIGAE + tsIPPt + tsQIPPt
CPO <- tsIPPa ~ tslnQ + tslnW + tsQ + tsQIPPt
instrumentos <- list (~ lag(tsQ,-1) + lag(tsIGAE,-1) + lag(tsIPPt,-1) + lag(tsQIPPt,-1), ~ lag(tsQ,-1) + lag(tslnQ,-1) + lag(tslnW,-1) + lag(tsQIPPt,-1))
system <- list(eq1 = Demanda, eq2 = CPO)
reg3SLS <- systemfit(system, "3SLS", inst = instrumentos, data = db)
summary(reg3SLS)
instrumentos <- list (~ lag(tsQ,-12) + lag(tsIGAE,-12) + lag(tsIPPt,-12) + lag(tsQIPPt,-12), ~ lag(tsQ,-12) + lag(tslnQ,-12) + lag(tslnW,-12) + lag(tsQIPPt,-12))
reg3SLS <- systemfit(system, "3SLS", inst = instrumentos, data = db)
summary(reg3SLS)
install.packages("ivreg")
